# Secrets & environment — never commit these
.env
.env.local
*.env
!.env.example
!*/.env.example

# Python
__pycache__/
*.pyc
.venv/

# Databases (regenerated by seed.py)
*.db
*.sqlite

# Node / Expo — ios/ and android/ are regenerated by `npx expo run:ios` (CNG)
node_modules/
.expo/
dist/
ios/
android/
*.log

# OS
.DS_Store

# Exception: pre-seeded demo database ships with the repo so Vercel deploys
# work instantly without depending on OpenFoodFacts at build time
!api/fair_demo.db
.vercel
